<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SmsSync"
                android:textSize="30sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/cred_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:gravity="end"
                android:background="@drawable/bg_bento_card"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/status_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <!-- Status indicator card -->
        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_bento_card"
            android:padding="20dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/status_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:textSize="36sp"
                android:gravity="center"
                android:text="&#x2705;" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/toggle_button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Pause"
                    android:textSize="15sp"
                    android:textAllCaps="false"
                    android:textColor="@color/button_primary_text"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    android:stateListAnimator="@null"
                    android:elevation="1dp" />

                <Button
                    android:id="@+id/test_message_button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Emulate SMS"
                    android:textSize="15sp"
                    android:textAllCaps="false"
                    android:textColor="@color/button_secondary_text"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    android:stateListAnimator="@null"
                    android:elevation="1dp" />

            </LinearLayout>

            <!-- Settings button full width -->
            <Button
                android:id="@+id/settings_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Settings"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:elevation="1dp" />

        </LinearLayout>

        <!-- Permission button -->
        <Button
            android:id="@+id/request_permission_button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="Grant SMS Permission"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:textColor="@color/button_primary_text"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            android:stateListAnimator="@null"
            android:elevation="1dp" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>