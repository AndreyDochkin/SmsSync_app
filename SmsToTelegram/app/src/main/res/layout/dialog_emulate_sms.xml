<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="Sender phone number"
        app:boxStrokeColor="@color/accent_primary"
        app:hintTextColor="@color/accent_primary"
        app:placeholderText="e.g. +1234567890"
        app:boxBackgroundColor="@color/background_card"
        app:boxStrokeWidth="1dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/emulate_sender_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="14sp"
            android:inputType="phone" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Message body"
        app:boxStrokeColor="@color/accent_primary"
        app:hintTextColor="@color/accent_primary"
        app:placeholderText="e.g. Your verification code is 123456"
        app:boxBackgroundColor="@color/background_card"
        app:boxStrokeWidth="1dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/emulate_body_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- SIM slot selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SIM slot"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/emulate_sim_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_bento_card"
        android:padding="8dp">

        <RadioButton
            android:id="@+id/emulate_sim_unknown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Unknown"
            android:checked="true"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_primary" />

        <RadioButton
            android:id="@+id/emulate_sim1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SIM 1"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_primary" />

        <RadioButton
            android:id="@+id/emulate_sim2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SIM 2"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_primary" />

    </RadioGroup>

</LinearLayout>